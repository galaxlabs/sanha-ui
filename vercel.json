{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://evaluation.sanha.org.pk/api/:path*"
    },
    {
      "source": "/files/:path*",
      "destination": "https://evaluation.sanha.org.pk/files/:path*"
    },
    {
      "source": "/assets/:path*",
      "destination": "https://evaluation.sanha.org.pk/assets/:path*"
    },
    {
      "source": "/((?!api/|files/|assets/).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",        "value": "SAMEORIGIN" }
      ]
    }
  ]
}

