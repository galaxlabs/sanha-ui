# ── VERCEL / PRODUCTION ──
# VITE_FRAPPE_URL is intentionally EMPTY so all /api/* requests go through
# Vercel's own proxy (vercel.json rewrites /api/* → evaluation.sanha.org.pk).
# This lets each user authenticate with their own session cookie — NOT an
# admin token — so role-based access works correctly.
VITE_FRAPPE_URL=

# DO NOT set VITE_API_KEY / VITE_API_SECRET here.
# Setting those would force every user to be seen as Administrator.
